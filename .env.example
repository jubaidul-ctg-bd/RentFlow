# ── API (NestJS) ───────────────────────────────────────────────
MONGODB_URI=mongodb://rentflow-db:27017/rentflow
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email ──────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_PROVIDER_API_KEY=re_...
EMAIL_FROM=noreply@rentflow.com

# ── Platform config ────────────────────────────────────────────
SERVICE_FEE_PERCENT=2.5
ADMIN_EMAIL=admin@rentflow.com
ADMIN_PASSWORD=change_me_admin_password
PLATFORM_URL=https://rentflow.com

# ── Client (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.rentflow.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
